load("@rules_cc//cc:defs.bzl", "cc_library")
load("@rules_foreign_cc//foreign_cc:defs.bzl", "cmake")
load("//tools/python:python_toolchain.bzl", "exec_python_tool")

package(default_visibility = ["//visibility:public"])

filegroup(
    name = "SDL3_srcs",
    srcs = glob(["SDL/**"]),
    visibility = ["//visibility:public"],
)

cc_library(
    name = "nuklear",
    hdrs = ["Nuklear/nuklear.h"],
    strip_include_prefix = "Nuklear",
    visibility = ["//visibility:public"],
)

exec_python_tool(
    name = "emsdk_python",
)

cmake(
    name = "sdl3_shared",
    defines = select({
        "@bazel_tools//src/conditions:darwin": [
            "CMAKE_OSX_DEPLOYMENT_TARGET=10.13",
        ],
        "//conditions:default": [],
    }),
    generate_args = ["-GNinja"],
    lib_source = ":SDL3_srcs",
    out_include_dir = "include",
    out_interface_libs = select({
        "@bazel_tools//src/conditions:windows": ["SDL3.lib"],
        "//conditions:default": [],
    }),
    out_shared_libs = select({
        "@bazel_tools//src/conditions:darwin": ["libSDL3.0.dylib"],
        "@bazel_tools//src/conditions:linux": ["libSDL3.so.0"],
        "@bazel_tools//src/conditions:windows": ["SDL3.dll"],
    }),
    visibility = ["//visibility:public"],
)

cmake(
    name = "sdl3_static",
    build_data = [":emsdk_python"],
    defines = select({
        "@bazel_tools//src/conditions:darwin": [
            "CMAKE_OSX_DEPLOYMENT_TARGET=10.13",
        ],
        "//conditions:default": [],
    }),
    env = select({
        "@platforms//cpu:wasm32": {
            "EMSDK_PYTHON": "$(execpath :emsdk_python)",
        },
        "@platforms//os:wasi": {
            "EMSDK_PYTHON": "$(execpath :emsdk_python)",
        },
        "//conditions:default": {},
    }),
    generate_args = [
        "-DSDL_STATIC=true",
        "-DSDL_SHARED=false",
        "-GNinja",
    ] + select({
        "@platforms//cpu:wasm32": ["-DEMSCRIPTEN=true"],
        "@platforms//os:wasi": ["-DEMSCRIPTEN=true"],
        "//conditions:default": [],
    }),
    lib_source = ":SDL3_srcs",
    out_include_dir = "include",
    out_static_libs = select({
        "@bazel_tools//src/conditions:darwin": ["libSDL3.a"],
        "@bazel_tools//src/conditions:linux": ["libSDL3.a"],
        "@platforms//cpu:wasm32": ["libSDL3.a"],
        "@platforms//os:wasi": ["libSDL3.a"],
        "@bazel_tools//src/conditions:windows": ["SDL3.lib"],  # is this right?
    }),
    visibility = ["//visibility:public"],
)
